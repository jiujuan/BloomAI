# BloomAI Environment Variables
# Copy this to .env.local and fill in your keys

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # optional

BLOOMAI_PORT=3718
DATA_DIR=~/.bloomai             # where bloomai.db is stored
NODE_ENV=production

# Chat attachments (MD / DOCX / PDF / TXT / CSV, 5MB each) are stored under
# <DATA_DIR_ATTACHMENT>/<YYYYMMDD>/. Defaults to <DATA_DIR>/attachment when unset.
DATA_DIR_ATTACHMENT=~/.bloomai/attachment

# Local proxy used automatically when a site is unreachable (web_fetch / web_extract)
LOCAL_HTTPS_PROXY=https://127.0.0.1:10808
