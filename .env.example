# BloomAI Environment Variables
# Copy this to .env.local and fill in your keys

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # optional

BLOOMAI_PORT=3718
DATA_DIR=~/.bloomai             # where bloomai.db is stored
NODE_ENV=production

# Chat attachments (MD / DOCX / PDF / TXT / CSV, 5MB each) are stored under
# <DATA_DIR_ATTACHMENT>/<YYYYMMDD>/. Defaults to <DATA_DIR>/attachment when unset.
DATA_DIR_ATTACHMENT=~/.bloomai/attachment

# Local proxy used automatically when a site is unreachable (web_fetch / web_extract)
LOCAL_HTTPS_PROXY=https://127.0.0.1:10808

# ── Memory System ─────────────────────────────────────────────────────────────
# Directory where Mastra memory.db is stored (Working Memory + Observational Memory).
# Defaults to ~/.bloomai/memory when unset.
MEMORY_DATA_DIR=~/.bloomai/memory

# How many recent messages to include directly in the LLM context window.
# Older messages are handled by Observational Memory (if enabled) or dropped.
# Default: 20
MEMORY_LAST_MESSAGES=20

# Model used by the Observer and Reflector in Observational Memory.
# Format: "provider/model-id"  e.g. anthropic/claude-haiku-4-5-20251001
#                                    openai/gpt-4o-mini
#                                    google/gemini-2.5-flash
# If left empty, auto-selects the cheapest model from whichever provider
# API key is already present in this file (Anthropic → OpenAI → Google).
# If no API key is found at all, Observational Memory is disabled (Working
# Memory still works without a model).
MEMORY_OBSERVATION_MODEL=
