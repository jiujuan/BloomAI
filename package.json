{
  "name": "bloomai",
  "private": true,
  "version": "0.1.0",
  "description": "BloomAI - Local-first AI Desktop Assistant",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --config electron.vite.config.ts",
    "build": "tsc --noEmit && vite build --config electron.vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint ok\"",
    "db:migrate": "node scripts/db-migrate.js",
    "start:server": "tsx src/server/index.ts",
    "start:server:legacy": "tsx packages/server/src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "sql.js": "^1.12.0",
    "tailwind-merge": "^2.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "prettier": "^3.2.5",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
