{
  "name": "bloomai",
  "private": true,
  "version": "0.1.0",
  "description": "BloomAI - Local-first AI Desktop Assistant",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/dev-with-utf8-console.cjs",
    "build": "tsc --noEmit && vite build --config electron.vite.config.ts",
    "test": "vitest run --pool=forks --maxWorkers=1 --minWorkers=1",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint ok\"",
    "db:migrate": "node scripts/db-migrate.js",
    "start:server": "tsx src/server/index.ts",
    "test:architecture": "vitest run src/server/http/route-dependency-boundary.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.91",
    "@ai-sdk/openai": "^3.0.79",
    "@ai-sdk/openai-compatible": "^2.0.55",
    "@ai-sdk/react": "^3.0.219",
    "@anthropic-ai/sdk": "^0.26.0",
    "@mastra/ai-sdk": "^1.6.0",
    "@mastra/core": "^1.46.0",
    "@mastra/libsql": "^1.15.0",
    "@mastra/memory": "^1.22.1",
    "@mastra/observability": "^1.15.2",
    "@mastra/otel-bridge": "^1.4.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ai": "^6.0.217",
    "clsx": "^2.1.1",
    "drizzle-orm": "^1.0.0-beta.16-c2458b2",
    "js-yaml": "^4.2.0",
    "lucide-react": "^0.383.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "4.0.0",
    "tailwind-merge": "^2.3.0",
    "undici": "^8.5.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "drizzle-kit": "^1.0.0-beta.17-8a36f93",
    "electron": "^37.10.3",
    "electron-builder": "^24.13.3",
    "prettier": "^3.2.5",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "build": {
    "appId": "com.bloomai.app",
    "productName": "BloomAI",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/playwright-core/**"
    ]
  }
}
